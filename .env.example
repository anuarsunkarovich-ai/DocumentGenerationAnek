APP__NAME=Lean Generator Backend
APP__VERSION=0.1.0
APP__DESCRIPTION=Template-driven backend for document generation.
APP__ENVIRONMENT=development
APP__DEBUG=true
APP__HOST=0.0.0.0
APP__PORT=8000
APP__API_PREFIX=/api/v1
APP__DOCS_URL=/docs
APP__REDOC_URL=/redoc
APP__OPENAPI_URL=/openapi.json
APP__CORS_ORIGINS=["http://localhost:5173"]

DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__NAME=lean_generator
DATABASE__USER=postgres
DATABASE__PASSWORD=postgres
DATABASE__ECHO=false
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20

STORAGE__ENDPOINT=localhost:9000
STORAGE__ACCESS_KEY=minioadmin
STORAGE__SECRET_KEY=minioadmin
STORAGE__BUCKET=documents
STORAGE__SECURE=false
STORAGE__REGION=
STORAGE__TEMPLATES_PREFIX=templates
STORAGE__ARTIFACTS_PREFIX=artifacts
STORAGE__CACHE_PREFIX=cache
STORAGE__PREVIEWS_PREFIX=previews
STORAGE__PRESIGNED_URL_EXPIRY_SECONDS=3600
STORAGE__AUTO_CREATE_BUCKET=true

GENERATION__CACHE_TTL_HOURS=24
GENERATION__JOB_TIMEOUT_SECONDS=180
GENERATION__MAX_UPLOAD_SIZE_MB=25
GENERATION__MAX_TEMPLATE_VARIABLES=250
GENERATION__MAX_DOCUMENT_BLOCKS=150
GENERATION__MAX_TABLE_ROWS=500
GENERATION__MAX_IMAGE_SIZE_MB=10
GENERATION__MAX_ARTIFACTS_PER_JOB=4
GENERATION__PREVIEW_ENABLED=true
