APP__NAME=Lean Generator Backend
APP__VERSION=0.1.0
APP__DESCRIPTION=Template-driven backend for document generation.
APP__ENVIRONMENT=production
APP__DEBUG=false
APP__HOST=0.0.0.0
APP__PORT=8000
APP__API_PREFIX=/api/v1
APP__DOCS_URL=/docs
APP__REDOC_URL=/redoc
APP__OPENAPI_URL=/openapi.json
APP__CORS_ORIGINS=["https://frontend.example.com"]

DATABASE__HOST=db
DATABASE__PORT=5432
DATABASE__NAME=lean_generator
DATABASE__USER=postgres
DATABASE__PASSWORD_FILE=/run/secrets/database_password
DATABASE__ECHO=false
DATABASE__POOL_SIZE=20
DATABASE__MAX_OVERFLOW=40

STORAGE__ENDPOINT=minio:9000
STORAGE__PUBLIC_ENDPOINT=storage.example.com
STORAGE__ACCESS_KEY_FILE=/run/secrets/storage_access_key
STORAGE__SECRET_KEY_FILE=/run/secrets/storage_secret_key
STORAGE__BUCKET=documents
STORAGE__SECURE=false
STORAGE__PUBLIC_SECURE=true
STORAGE__REGION=
STORAGE__TEMPLATES_PREFIX=templates
STORAGE__ARTIFACTS_PREFIX=artifacts
STORAGE__CACHE_PREFIX=cache
STORAGE__PREVIEWS_PREFIX=previews
STORAGE__PRESIGNED_URL_EXPIRY_SECONDS=3600
STORAGE__AUTO_CREATE_BUCKET=true

REDIS__HOST=redis
REDIS__PORT=6379
REDIS__BROKER_DB=0
REDIS__RESULT_DB=1
REDIS__PASSWORD_FILE=/run/secrets/redis_password

GENERATION__CACHE_TTL_HOURS=24
GENERATION__JOB_TIMEOUT_SECONDS=180
GENERATION__MAX_UPLOAD_SIZE_MB=25
GENERATION__MAX_TEMPLATE_VARIABLES=250
GENERATION__MAX_DOCUMENT_BLOCKS=150
GENERATION__MAX_TABLE_ROWS=500
GENERATION__MAX_IMAGE_SIZE_MB=10
GENERATION__MAX_ARTIFACTS_PER_JOB=4
GENERATION__PREVIEW_ENABLED=true

AUTH__JWT_SECRET_KEY_FILE=/run/secrets/jwt_signing_key
AUTH__JWT_ALGORITHM=HS256
AUTH__ISSUER=lean-generator-backend
AUTH__AUDIENCE=lean-generator-clients
AUTH__ACCESS_TOKEN_TTL_MINUTES=15
AUTH__REFRESH_TOKEN_TTL_DAYS=30
AUTH__PASSWORD_MIN_LENGTH=8

WORKER__QUEUE_NAME=document-generation
WORKER__MAX_RETRIES=4
WORKER__RETRY_BACKOFF_SECONDS=15
WORKER__STALE_JOB_TIMEOUT_SECONDS=300
WORKER__STALE_JOB_RECOVERY_BATCH_SIZE=100
WORKER__RESULT_EXPIRES_SECONDS=3600
WORKER__MAINTENANCE_CLEANUP_INTERVAL_MINUTES=60

RETENTION__GENERATED_ARTIFACT_RETENTION_DAYS=30
RETENTION__FAILED_JOB_RETENTION_DAYS=14
RETENTION__AUDIT_LOG_RETENTION_DAYS=90
RETENTION__TEMP_DATA_RETENTION_HOURS=24
RETENTION__CLEANUP_BATCH_SIZE=250

API_KEYS__HEADER_NAME=X-API-Key
API_KEYS__PUBLIC_PREFIX=/public
API_KEYS__REQUESTS_PER_MINUTE_PER_KEY=120
API_KEYS__REQUESTS_PER_MINUTE_PER_ORG=600
API_KEYS__REQUESTS_PER_DAY_PER_KEY=5000
API_KEYS__REQUESTS_PER_DAY_PER_ORG=50000

OBSERVABILITY__SENTRY_DSN_FILE=/run/secrets/sentry_dsn
OBSERVABILITY__SENTRY_TRACES_SAMPLE_RATE=0.1
OBSERVABILITY__REQUEST_ID_HEADER=X-Request-ID
OBSERVABILITY__CORRELATION_ID_HEADER=X-Correlation-ID
