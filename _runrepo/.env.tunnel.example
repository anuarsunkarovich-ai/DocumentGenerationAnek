# Copy this file to `.env.tunnel` when you want to demo the stack over Cloudflare Tunnel.
#
# For Quick Tunnels:
# - start one tunnel for the API on localhost:8000
# - start one tunnel for MinIO on localhost:9000
# - copy only the hostname part without `https://`
#
# Example:
# STORAGE__PUBLIC_ENDPOINT=gentle-meadow-123.trycloudflare.com

STORAGE__PUBLIC_ENDPOINT=
STORAGE__PUBLIC_SECURE=true

# Leave localhost here unless you have a browser frontend on a public hostname.
# If you do, add that origin too.
APP__CORS_ORIGINS=["http://localhost:5173"]
